---
import Layout from '../layouts/Layout.astro';
import { cuisines, dietaryOptions, timeOptions, servingOptions, getCuisineName, getTimeLabel } from '../utils/recipes';
import recipesData from '../data/recipes.json';

const recipes = recipesData.recipes;
---

<Layout title="Home">
  <!-- Header -->
  <header class="bg-card-bg border-b border-secondary sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center">
          <span class="text-white text-xl">🍳</span>
        </div>
        <h1 class="text-xl font-bold text-text">晚餐 recipes</h1>
      </div>
      <nav class="hidden md:flex items-center gap-6">
        <a href="/-IThund-dinner-recipe/#recipes" class="text-text-muted hover:text-primary transition-colors">食譜</a>
        <a href="/-IThund-dinner-recipe/#about" class="text-text-muted hover:text-primary transition-colors">關於</a>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="bg-secondary/30 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-text mb-4">
        今晚煮咩好？
      </h2>
      <p class="text-xl text-text-muted max-w-2xl mx-auto mb-8">
        搵啱Budget、啱Time、啱口味嘅Recipes
      </p>
      
      <!-- Search Bar -->
      <div class="max-w-xl mx-auto relative flex gap-3">
        <div class="relative flex-1">
          <input
            type="text"
            id="searchInput"
            placeholder="Search recipes... 搵食譜..."
            class="w-full px-6 py-4 bg-card-bg rounded-2xl border border-secondary focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-lg"
          />
          <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <button
          id="diceBtn"
          class="px-5 py-4 bg-primary hover:bg-primary/90 text-white rounded-2xl border border-primary transition-all text-lg font-semibold flex items-center gap-2 shrink-0"
          title="Random pick! 隨機選擇"
        >
          <span class="text-xl">🎲</span>
          <span class="hidden sm:inline">隨機</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Filter Section -->
  <section id="recipes" class="py-8 border-b border-secondary">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Filter Toggle (Mobile) -->
      <button id="filterToggle" class="md:hidden w-full py-3 bg-card-bg rounded-xl border border-secondary flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
        </svg>
        <span class="font-medium">Filters 篩選</span>
      </button>

      <!-- Filter Panel -->
      <div id="filterPanel" class="hidden md:block space-y-6">
        <!-- Cuisine Filters -->
        <div>
          <h3 class="font-semibold text-text mb-3"> Cuisine 菜式</h3>
          <div class="flex flex-wrap gap-2">
            <button class="cuisine-btn active px-4 py-2 rounded-full border-2 border-primary bg-primary text-white transition-colors" data-cuisine="all">
              All 全部
            </button>
            {cuisines.map((c) => (
              <button class="cuisine-btn px-4 py-2 rounded-full border-2 border-secondary hover:border-primary transition-colors" data-cuisine={c.id}>
                <span class="mr-1">{c.icon}</span>
                {c.nameZh}
              </button>
            ))}
          </div>
        </div>

        <!-- Budget -->
        <div>
          <h3 class="font-semibold text-text mb-3">Budget Budget (HKD)</h3>
          <div class="flex items-center gap-4">
            <span class="text-text-muted">$0</span>
            <input
              type="range"
              id="budgetSlider"
              min="0"
              max="500"
              value="500"
              class="flex-1 h-2 bg-secondary rounded-lg appearance-none cursor-pointer accent-primary"
            />
            <span class="text-text-muted">$500</span>
            <span id="budgetValue" class="text-primary font-semibold min-w-[60px]">$500</span>
          </div>
        </div>

        <!-- Serving Size -->
        <div>
          <h3 class="font-semibold text-text mb-3">Serves 份量</h3>
          <div class="flex flex-wrap gap-3">
            {servingOptions.map((s) => (
              <button class="serving-btn px-5 py-3 rounded-xl border-2 border-secondary hover:border-primary bg-card-bg transition-all flex items-center gap-2" data-serves={s.id}>
                <span class="text-2xl">{s.icon}</span>
                <span class="font-medium">{s.nameZh}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Time -->
        <div>
          <h3 class="font-semibold text-text mb-3">Cooking Time 時間</h3>
          <div class="flex flex-wrap gap-2">
            {timeOptions.map((t) => (
              <button class="time-btn px-4 py-2 rounded-full border-2 border-secondary hover:border-primary bg-card-bg transition-colors" data-time={t.id}>
                {t.nameZh}
                {t.id !== 'all' && <span class="text-text-muted text-sm ml-1">({t.max} mins)</span>}
              </button>
            ))}
          </div>
        </div>

        <!-- Dietary -->
        <div>
          <h3 class="font-semibold text-text mb-3">Dietary 飲食需求</h3>
          <div class="flex flex-wrap gap-2">
            {dietaryOptions.map((d) => (
              <button class="dietary-btn px-4 py-2 rounded-full border-2 border-secondary hover:border-primary bg-card-bg transition-colors" data-dietary={d.id}>
                {d.nameZh}
              </button>
            ))}
          </div>
        </div>

        <!-- Clear Filters -->
        <button id="clearFilters" class="text-primary hover:text-accent transition-colors">
          Clear all filters 清除篩選
        </button>
      </div>
    </div>
  </section>

  <!-- Results Count -->
  <section class="py-4 border-b border-secondary">
    <div class="max-w-7xl mx-auto px-4">
      <p id="resultsCount" class="text-text-muted">
        Showing {recipes.length} recipes
      </p>
    </div>
  </section>

  <!-- Recipe Grid (Pinterest Masonry Style) -->
  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4">
      <div id="recipeGrid" class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-6">
        {recipes.map((recipe) => (
          <article class="recipe-card bg-card-bg rounded-2xl overflow-hidden border border-secondary hover:border-primary hover:shadow-xl transition-all cursor-pointer" data-cuisine={recipe.cuisine} data-budget={recipe.budget} data-serves={recipe.serves} data-time={recipe.time} data-dietary={recipe.dietary.join(',')} data-ingredients={recipe.ingredients.join('|')}>
            <a href={`/-IThund-dinner-recipe/recipe/${recipe.slug}`} class="block">
              <div class="aspect-[4/3] overflow-hidden bg-secondary/30">
                <img
                  src={recipe.image}
                  alt={recipe.title}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs px-2 py-1 bg-secondary/50 rounded-full text-text-muted">
                    {getCuisineName(recipe.cuisine)}
                  </span>
                  <span class="text-xs px-2 py-1 bg-accent/20 rounded-full text-accent">
                    {getTimeLabel(recipe.time)}
                  </span>
                </div>
                <h3 class="font-bold text-lg text-text mb-1">{recipe.title}</h3>
                <div class="flex items-center justify-between text-sm text-text-muted">
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    ${recipe.budget}
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                    {recipe.serves} 人
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {recipe.time} min
                  </span>
                </div>
                {recipe.dietary.length > 0 && (
                  <div class="flex flex-wrap gap-1 mt-2">
                    {recipe.dietary.map((d) => (
                      <span class="text-xs px-2 py-0.5 bg-accent/10 rounded-full text-accent">
                        {d}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- No Results -->
      <div id="noResults" class="hidden text-center py-12">
        <div class="text-6xl mb-4">🍽️</div>
        <h3 class="text-xl font-semibold text-text mb-2">No recipes found</h3>
        <p class="text-text-muted">Try adjusting your filters</p>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="bg-secondary/30 py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-text mb-4">關於呢個網站</h2>
        <p class="text-text-muted mb-6">
          為香港繁忙既OL同打工仔提供Quick Recipes,
          搵啱Budget、啱Time既食譜。
          適合關注健康既朋友，包括糖尿病患者。
        </p>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <span class="px-3 py-1 bg-card-bg rounded-full text-text-muted">
            🌿 健康食材
          </span>
          <span class="px-3 py-1 bg-card-bg rounded-full text-text-muted">
            ⏱️ 30分鐘內
          </span>
          <span class="px-3 py-1 bg-card-bg rounded-full text-text-muted">
            💰 Budget friendly
          </span>
          <span class="px-3 py-1 bg-card-bg rounded-full text-text-muted">
            🏥 糖尿病友好
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Scroll to Top -->
  <button
    id="scrollTopBtn"
    class="fixed bottom-6 right-4 sm:bottom-8 sm:right-8 w-11 h-11 bg-primary text-white rounded-full shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 hover:bg-primary/90 z-40"
    aria-label="Scroll to top"
  >
    <span class="text-lg">⬆</span>
  </button>

  <!-- Footer -->
  <footer class="bg-text text-background py-8">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p>今晚煮咩好？© 2026Dinner Recipe HK</p>
    </div>
  </footer>
</Layout>

<script define:vars={{ cuisines, dietaryOptions, timeOptions, servingOptions }}>
  // State
  let filters = {
    cuisine: 'all',
    budget: 500,
    serves: null,
    time: 'all',
    dietary: [],
    search: ''
  };

  // DOM Elements
  const searchInput = document.getElementById('searchInput');
  const budgetSlider = document.getElementById('budgetSlider');
  const budgetValue = document.getElementById('budgetValue');
  const filterToggle = document.getElementById('filterToggle');
  const filterPanel = document.getElementById('filterPanel');
  const clearFilters = document.getElementById('clearFilters');
  const resultsCount = document.getElementById('resultsCount');
  const noResults = document.getElementById('noResults');

  // Cuisine buttons
  document.querySelectorAll('.cuisine-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cuisine-btn').forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('border-secondary', 'bg-card-bg');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('border-secondary', 'bg-card-bg');
      filters.cuisine = btn.dataset.cuisine;
      filterRecipes();
    });
  });

  // Budget slider
  budgetSlider.addEventListener('input', (e) => {
    filters.budget = parseInt(e.target.value);
    budgetValue.textContent = `$${filters.budget}`;
    filterRecipes();
  });

  // Serving buttons
  document.querySelectorAll('.serving-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.serving-btn').forEach(b => {
        b.classList.remove('bg-primary', 'border-primary', 'bg-accent/10');
      });
      const isActive = btn.classList.contains('bg-primary');
      if (isActive) {
        btn.classList.remove('bg-primary', 'border-primary', 'bg-accent/10');
        filters.serves = null;
      } else {
        btn.classList.add('bg-primary', 'border-primary', 'bg-accent/10');
        filters.serves = parseInt(btn.dataset.serves);
      }
      filterRecipes();
    });
  });

  // Time buttons
  document.querySelectorAll('.time-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.time-btn').forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('border-secondary', 'bg-card-bg');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('border-secondary', 'bg-card-bg');
      filters.time = btn.dataset.time;
      filterRecipes();
    });
  });

  // Dietary buttons
  document.querySelectorAll('.dietary-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('bg-primary');
      btn.classList.toggle('text-white');
      btn.classList.toggle('border-primary');
      
      if (btn.classList.contains('bg-primary')) {
        filters.dietary.push(btn.dataset.dietary);
      } else {
        filters.dietary = filters.dietary.filter(d => d !== btn.dataset.dietary);
      }
      filterRecipes();
    });
  });

  // Search
  searchInput.addEventListener('input', (e) => {
    filters.search = e.target.value;
    filterRecipes();
  });

  // Filter toggle (mobile)
  filterToggle.addEventListener('click', () => {
    filterPanel.classList.toggle('hidden');
  });

  // Clear filters
  clearFilters.addEventListener('click', () => {
    filters = {
      cuisine: 'all',
      budget: 500,
      serves: null,
      time: 'all',
      dietary: [],
      search: ''
    };
    
    budgetSlider.value = 500;
    budgetValue.textContent = '$500';
    searchInput.value = '';
    
    document.querySelectorAll('.cuisine-btn')[0].click();
    document.querySelectorAll('.time-btn')[0].click();
    document.querySelectorAll('.serving-btn, .dietary-btn').forEach(b => {
      b.classList.remove('bg-primary', 'border-primary', 'text-white');
    });
    
    filterRecipes();
  });

  // Filter function
  function filterRecipes() {
    const cards = document.querySelectorAll('.recipe-card');
    let visibleCount = 0;
    
    cards.forEach(card => {
      const cuisine = card.dataset.cuisine;
      const budget = parseInt(card.dataset.budget);
      const serves = parseInt(card.dataset.serves);
      const time = parseInt(card.dataset.time);
      const dietary = card.dataset.dietary.split(',').filter(d => d);
      
      let show = true;
      
      // Cuisine filter
      if (filters.cuisine !== 'all' && cuisine !== filters.cuisine) {
        show = false;
      }
      
      // Budget filter
      if (budget > filters.budget) {
        show = false;
      }
      
      // Serves filter
      if (filters.serves) {
        const option = servingOptions.find(s => s.id === filters.serves);
        if (option) {
          const [min, max] = option.id === 1 ? [1, 1] : option.id === 2 ? [2, 2] : option.id === 4 ? [3, 4] : [5, 100];
          if (serves < min || serves > max) {
            show = false;
          }
        }
      }
      
      // Time filter
      if (filters.time !== 'all') {
        const option = timeOptions.find(t => t.id === filters.time);
        if (option && time > option.max) {
          show = false;
        }
      }
      
      // Dietary filter
      if (filters.dietary.length > 0) {
        const hasAll = filters.dietary.every(d => dietary.includes(d));
        if (!hasAll) {
          show = false;
        }
      }
      
      // Search filter
      if (filters.search) {
        const cardText = card.textContent.toLowerCase();
        const ingredients = card.dataset.ingredients.toLowerCase();
        const searchTerm = filters.search.toLowerCase();
        
        if (!cardText.includes(searchTerm) && !ingredients.includes(searchTerm)) {
          show = false;
        }
      }
      
      if (show) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });
    
    // Update count
    resultsCount.textContent = `Showing ${visibleCount} recipes`;
    
    // Show/hide no results
    if (visibleCount === 0) {
      noResults.classList.remove('hidden');
    } else {
      noResults.classList.add('hidden');
    }
  }

  // Initialize
  document.querySelectorAll('.cuisine-btn')[0].classList.add('bg-primary', 'text-white');
  document.querySelectorAll('.cuisine-btn')[0].classList.remove('border-secondary', 'bg-card-bg');
  document.querySelectorAll('.time-btn')[0].classList.add('bg-primary', 'text-white');
  document.querySelectorAll('.time-btn')[0].classList.remove('border-secondary', 'bg-card-bg');

  // Random dice picker
  const diceBtn = document.getElementById('diceBtn');

  diceBtn.addEventListener('click', () => {
    const visibleCards = Array.from(document.querySelectorAll('.recipe-card:not(.hidden)'));

    if (visibleCards.length === 0) return;

    const randomCard = visibleCards[Math.floor(Math.random() * visibleCards.length)];

    // Remove highlight from any previously highlighted card
    document.querySelectorAll('.dice-highlight').forEach(el => {
      el.classList.remove('dice-highlight');
    });

    // Scroll to the card
    randomCard.scrollIntoView({ behavior: 'smooth', block: 'center' });

    // Apply highlight
    randomCard.classList.add('dice-highlight');

    // Remove highlight after 2.5s so it can be triggered again
    setTimeout(() => {
      randomCard.classList.remove('dice-highlight');
    }, 2500);
  });

  // Scroll to top button
  const scrollTopBtn = document.getElementById('scrollTopBtn');
  if (scrollTopBtn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        scrollTopBtn.classList.remove('opacity-0', 'pointer-events-none');
        scrollTopBtn.classList.add('opacity-100');
      } else {
        scrollTopBtn.classList.add('opacity-0', 'pointer-events-none');
        scrollTopBtn.classList.remove('opacity-100');
      }
    });
    scrollTopBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>